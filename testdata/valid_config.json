{
  "version": 1,
  "coverage": [
    {
      "name": "backend",
      "path": "coverage/lcov.info",
      "format": "lcov",
      "threshold": {
        "line": 80,
        "branch": 70,
        "function": 80
      }
    },
    {
      "name": "api",
      "path": "cover.out",
      "format": "gocover",
      "threshold": {
        "line": 75
      }
    }
  ]
}
